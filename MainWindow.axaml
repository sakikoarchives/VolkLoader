<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="VolkLoaderAvalonia.MainWindow"
        Width="1000"
        Height="850"
        MinWidth="900"
        MinHeight="700"
        Title="VOLKLOADER - Avalonia port">
  <Grid ColumnDefinitions="240,*">
    <Border x:Name="Sidebar"
            Grid.Column="0"
            BorderThickness="1">
      <StackPanel Margin="25,20,25,20" Spacing="10">
        <Button x:Name="HomeButton" Height="55" Click="OnHomeClicked" />
        <Button x:Name="GamesButton" Height="55" Click="OnGamesClicked" />
        <Button x:Name="ServerButton" Height="55" Click="OnServerClicked" />
        <Button x:Name="SettingsButton" Height="55" Click="OnSettingsClicked" />
      </StackPanel>
    </Border>

    <Grid Grid.Column="1" Margin="10">
      <Border x:Name="ContainerBorder"
              BorderThickness="1"
              CornerRadius="15"
              Padding="15">
        <ScrollViewer>
          <StackPanel x:Name="ContentPanel" Spacing="12" />
        </ScrollViewer>
      </Border>

      <Border x:Name="OverlayBorder"
              IsVisible="False"
              Width="620"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Padding="22"
              BorderThickness="2"
              CornerRadius="15"
              ZIndex="100">
        <StackPanel x:Name="OverlayPanel" Spacing="12" />
      </Border>
    </Grid>
  </Grid>
</Window>
